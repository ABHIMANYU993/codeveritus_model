   "source": [
    "import torch\n",
    "from transformers import AutoModelForSequenceClassification, AutoTokenizer\n",
    "from huggingface_hub import login\n",
    "\n",
    "# Log in to Hugging Face using your API token\n",
    "login(token=\"os.getenv("HF_TOKEN")\")\n",
    "\n",
    "# Function to load the model and tokenizer\n",
    "def load_model():\n",
    "    # Hugging Face model repository name (gated/private)\n",
    "    model_name = \"os.getenv('DB_USER', 'user')/ai-code-detector\"\n",
    "    \n",
    "    # Load the tokenizer and the model\n",
    "    tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
    "    model = AutoModelForSequenceClassification.from_pretrained(model_name)\n",
    "\n",
    "    model.eval()  # Set the model to evaluation mode\n",
    "    return model, tokenizer\n",
    "\n",
    "# Preprocessing function\n",
    "def preprocess_input_code(code_samples, tokenizer):\n",
    "    tokenized_samples = []\n",
    "    attention_masks = []\n",
    "\n",
    "    for code_sample in code_samples:\n",
    "        tokenized_input = tokenizer(\n",
    "            code_sample,\n",
    "            padding='max_length',\n",
    "            truncation=True,\n",
    "            max_length=512,\n",
    "            return_tensors='pt'\n",
    "        )\n",
    "        tokenized_samples.append(tokenized_input['input_ids'].squeeze(0))\n",
    "        attention_masks.append(tokenized_input['attention_mask'].squeeze(0))\n",
    "\n",
    "    # Convert to PyTorch tensors\n",
    "    tokens = torch.stack(tokenized_samples)\n",
    "    masks = torch.stack(attention_masks)\n",
    "    return tokens, masks\n",
    "\n",
    "# Prediction function\n",
    "def predict_code_samples(model, tokenizer, code_samples):\n",
    "    tokens, masks = preprocess_input_code(code_samples, tokenizer)\n",
    "    \n",
    "    # No need to specify device, it will automatically choose\n",
    "    with torch.no_grad():\n",
    "        outputs = model(tokens, attention_mask=masks)\n",
    "        _, preds = torch.max(outputs.logits, dim=1)\n",
    "        prediction_labels = [\"AI-generated\" if pred == 1 else \"Human-generated\" for pred in preds.cpu().numpy()]\n",
    "    return prediction_labels\n",
    "\n",
    "# Example usage:\n",
    "if __name__ == \"__main__\":\n",
    "    model, tokenizer = load_model()  # Load the model and tokenizer\n",
    "    code_samples = [\"def fibonacci(n):\", \"return n if n <= 1 else fibonacci(n-1) + fibonacci(n-2)\"]  # Example input\n",
    "    predictions = predict_code_samples(model, tokenizer, code_samples)  # Get predictions\n",
    "\n",
    "    for code, pred in zip(code_samples, predictions):\n",
    "        print(f\"Code Sample: {code}\\nPrediction: {pred}\\n\")\n"
   ]
  },
